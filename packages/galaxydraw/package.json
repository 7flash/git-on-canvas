{
    "name": "galaxydraw",
    "version": "0.2.0",
    "description": "Infinite canvas framework for spatial applications. Zero dependencies, ~31KB.",
    "type": "module",
    "main": "src/index.ts",
    "types": "src/index.ts",
    "exports": {
        ".": {
            "bun": "./src/index.ts",
            "import": "./dist/index.js",
            "types": "./src/index.ts"
        },
        "./css": "./src/galaxydraw.css"
    },
    "files": [
        "dist",
        "src"
    ],
    "scripts": {
        "build": "bun build src/index.ts --outdir dist --format esm --sourcemap=external",
        "dev": "bun run --watch demo/server.ts",
        "prepublishOnly": "bun run build"
    },
    "keywords": [
        "canvas",
        "infinite-canvas",
        "spatial",
        "pan",
        "zoom",
        "drag",
        "cards",
        "dashboard",
        "visualization",
        "touch",
        "pinch-to-zoom"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/7flash/git-on-canvas",
        "directory": "packages/galaxydraw"
    },
    "license": "MIT",
    "author": "7flash",
    "devDependencies": {
        "typescript": "^5.4.0"
    }
}