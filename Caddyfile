# Caddyfile for gitmaps.xyz
#
# Architecture:
# - Root `/`   → Static landing page (gonc-web)
# - `/{owner}/{repo}` → GitMaps canvas app on port 3335
#
# Caddy handles:
# - Automatic HTTPS (Let's Encrypt)
# - Static file serving for landing page
# - Reverse proxy to GitMaps app for repo routes
# - WebSocket upgrade for real-time features
# - Gzip compression
# - Security headers
#
# Deploy:
#   1. Install Caddy on your server
#   2. Copy this file to /etc/caddy/Caddyfile
#   3. sudo systemctl reload caddy
#
# Or run standalone:
#   caddy run --config Caddyfile

gitmaps.xyz {
    # Static landing page at root
    handle / {
        root * /srv/landing
        file_server
        try_files {path} /index.html
    }

    # Landing page static assets (css, js, images)
    handle /styles.css {
        root * /srv/landing
        file_server
    }
    handle /script.js {
        root * /srv/landing
        file_server
    }
    handle /canvas-demo.js {
        root * /srv/landing
        file_server
    }
    handle /hero.png {
        root * /srv/landing
        file_server
    }
    handle /hero-demo.webp {
        root * /srv/landing
        file_server
    }
    handle /img-* {
        root * /srv/landing
        file_server
    }
    handle /concepts.html {
        root * /srv/landing
        file_server
    }
    handle /pitch.html {
        root * /srv/landing
        file_server
    }

    # All other routes → GitMaps app (owner/repo patterns)
    handle {
        reverse_proxy localhost:3335 {
            # WebSocket support
            header_up Connection {>Connection}
            header_up Upgrade {>Upgrade}
        }
    }

    # Compression
    encode gzip zstd

    # Security headers
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }
}

# Redirect www to apex
www.gitmaps.xyz {
    redir https://gitmaps.xyz{uri} permanent
}
